<?xml version="1.0"?>
<robot name="diff_drive_robot">

  <!-- ============================================================
       Body dimensions:  0.50 m (L) x 0.30 m (W) x 0.15 m (H)
       Drive wheels:     radius 0.10 m, width 0.05 m
       Caster:           radius 0.05 m (rear)
       base_link origin: centre of body box, 0.175 m above ground
         (wheel_radius 0.10 + wheel_to_body_offset 0.075)
       Wheel separation: 0.35 m (centre-to-centre)
  ============================================================ -->

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.15"/></geometry>
      <material name="blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.3 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <!-- solid box: Ixx=m/12*(h²+d²), Iyy=m/12*(w²+d²), Izz=m/12*(w²+h²) -->
      <inertia ixx="0.0875" ixy="0.0" ixz="0.0"
               iyy="0.2292" iyz="0.0"
               izz="0.2917"/>
    </inertial>
  </link>

  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0026" ixy="0.0" ixz="0.0"
               iyy="0.0026" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y=+0.175: half wheel-sep; z=-0.075: wheel centre below body centre -->
    <origin xyz="0.0 0.175 -0.075" rpy="-1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0026" ixy="0.0" ixz="0.0"
               iyy="0.0026" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.175 -0.075" rpy="-1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- REAR CASTER -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0"
               iyy="0.0005" iyz="0.0"
               izz="0.0005"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- rear of body, bottom of body: x=-0.20, z=-0.125 → ground at 0.05 = sphere radius -->
    <origin xyz="-0.20 0.0 -0.125" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       Gazebo Fortress (Ignition Gazebo 6) plugins
  ============================================================ -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.35</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <!-- These topic names are bridged to ROS2 in sim.launch.py -->
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

</robot>
