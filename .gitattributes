# Force LF line endings in the repo for all text files.
# This prevents Windows CRLF vs LF noise in diffs.
* text=auto eol=lf

# Explicitly mark binary files so git never touches their line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.deb binary
*.so binary
*.stl binary
*.dae binary
